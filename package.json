{
  "name": "javbus-api",
  "version": "2.1.5",
  "description": "JavBus API",
  "keywords": [
    "api",
    "javbus"
  ],
  "homepage": "https://github.com/ovnrain/javbus-api#readme",
  "license": "MIT",
  "author": {
    "name": "ovnrain",
    "email": "ovnrain@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ovnrain/javbus-api.git"
  },
  "type": "module",
  "main": "index.js",
  "scripts": {
    "start": "node -r dotenv/config dist/server.js",
    "dev": "tsx watch --clear-screen=false -r dotenv/config api/server.ts",
    "build": "tsc",
    "vercel-build": "tsc",
    "lint": "oxlint --deny-warnings",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "check": "oxlint --deny-warnings && oxfmt --check",
    "prepare": "husky"
  },
  "dependencies": {
    "bytes": "^3.1.2",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "express-validator": "^7.3.2",
    "got": "^15.0.5",
    "http-errors": "^2.0.1",
    "https-proxy-agent": "^9.0.0",
    "memorystore": "^1.6.8",
    "node-html-parser": "^7.1.0",
    "probe-image-size": "^7.3.0",
    "qs": "^6.15.2",
    "socks-proxy-agent": "^10.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bytes": "^3.1.5",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.19.0",
    "@types/http-errors": "^2.0.5",
    "@types/node": "^25.9.1",
    "@types/probe-image-size": "^7.2.5",
    "@types/qs": "^6.15.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "oxfmt": "^0.51.0",
    "oxlint": "^1.66.0",
    "oxlint-tsgolint": "^0.23.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  },
  "lint-staged": {
    "*.{ts,json}": [
      "oxfmt"
    ],
    "*.ts": [
      "oxlint --deny-warnings"
    ]
  },
  "packageManager": "pnpm@11.1.2"
}
